<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Friday Night Poker</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
  :root {
    --bg: #0a0a0a; --card: #141414; --card2: #1e1e1e;
    --border: #2a2a2a; --accent: #c8f135; --text: #ffffff;
    --muted: #888; --red: #e74c3c; --green: #2ecc71;
  }
  html, body { width:100%; height:100%; background:var(--bg); color:var(--text); font-family:'Courier New',monospace; overflow:hidden; }
  .app { width:100vw; height:100vh; height:100dvh; display:flex; flex-direction:column; overflow:hidden; }
.header { background:var(--card); border-bottom:1px solid var(--border); padding:12px 16px; display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
.header-title { font-size:13px; font-weight:bold; letter-spacing:2px; color:var(--accent); }
.icon-btn { width:36px; height:36px; border-radius:50%; border:1px solid var(--border); background:var(--card2); color:var(--text); font-size:16px; cursor:pointer; display:flex; align-items:center; justify-content:center; }
.stats-bar { background:var(--card); border-bottom:1px solid var(--border); display:grid; grid-template-columns:1fr 1fr 1fr; flex-shrink:0; }
.stat { padding:10px 14px; border-right:1px solid var(--border); }
.stat:last-child { border-right:none; }
.stat-label { font-size:9px; letter-spacing:1.5px; color:var(--muted); text-transform:uppercase; margin-bottom:3px; }
.stat-value { font-size:20px; font-weight:bold; color:var(--accent); }
.stat-value.white { color:var(--text); }
.game-info { background:var(--card2); border-bottom:1px solid var(--border); padding:10px 16px; display:flex; gap:16px; align-items:center; flex-shrink:0; }
.game-field { display:flex; flex-direction:column; gap:2px; flex:1; }
.game-field label { font-size:9px; letter-spacing:1.5px; color:var(--muted); text-transform:uppercase; }
.game-field input { background:transparent; border:none; color:var(--text); font-family:'Courier New',monospace; font-size:13px; outline:none; width:100%; }
.add-player-bar { background:var(--card); border-bottom:1px solid var(--border); padding:10px 16px; display:flex; gap:8px; flex-shrink:0; }
.add-player-bar select { flex:1; background:var(--card2); border:1px solid var(--border); border-radius:6px; color:var(--text); font-family:'Courier New',monospace; font-size:13px; padding:8px 10px; outline:none; appearance:none; -webkit-appearance:none; cursor:pointer; }
.add-player-bar select option { background:var(--card2); color:var(--text); }
.buyin-input { width:70px !important; flex:none !important; text-align:center; background:var(--card2); border:1px solid var(--border); border-radius:6px; color:var(--text); font-family:'Courier New',monospace; font-size:13px; padding:8px 10px; outline:none; }
.add-btn { background:var(--accent); color:#000; border:none; border-radius:6px; font-family:'Courier New',monospace; font-size:11px; font-weight:bold; letter-spacing:1px; padding:8px 14px; cursor:pointer; white-space:nowrap; text-transform:uppercase; }
.custom-bar { background:var(--card); border-bottom:1px solid var(--border); padding:8px 16px; display:none; gap:8px; flex-shrink:0; }
.custom-bar.visible { display:flex; }
.custom-bar input { flex:1; background:var(--card2); border:1px solid var(--accent); border-radius:6px; color:var(--text); font-family:'Courier New',monospace; font-size:13px; padding:8px 12px; outline:none; }
.custom-bar input::placeholder { color:var(--muted); }
.new-player-row { background:var(--card); border-bottom:1px solid var(--border); padding:5px 16px; display:flex; justify-content:flex-end; flex-shrink:0; }
.new-player-btn { background:none; border:1px dashed var(--border); border-radius:6px; color:var(--muted); font-family:'Courier New',monospace; font-size:10px; padding:4px 12px; cursor:pointer; letter-spacing:1px; }
.new-player-btn.active { border-color:var(--accent); color:var(--accent); }
.tabs { display:flex; background:var(--card); border-bottom:1px solid var(--border); flex-shrink:0; }
.tab { flex:1; padding:10px; text-align:center; font-size:10px; letter-spacing:1px; color:var(--muted); cursor:pointer; text-transform:uppercase; border-bottom:2px solid transparent; transition:all 0.2s; }
.tab.active { color:var(--accent); border-bottom-color:var(--accent); }
.tab-content { flex:1; overflow:hidden; display:none; flex-direction:column; }
.tab-content.active { display:flex; }
.players-header { display:grid; grid-template-columns:44px 1fr 55px 86px 60px 28px; padding:8px 12px; background:var(--card); border-bottom:1px solid var(--border); flex-shrink:0; }
.players-header span { font-size:9px; letter-spacing:1px; color:var(--muted); text-transform:uppercase; }
.players-header span:nth-child(3), .players-header span:nth-child(4), .players-header span:nth-child(5) { text-align:center; }
.players-list { flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch; background:var(--bg); }
.player-row { display:grid; grid-template-columns:44px 1fr 55px 86px 60px 28px; align-items:center; padding:10px 12px; border-bottom:1px solid var(--border); background:var(--bg); }
.avatar { width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:bold; color:#000; flex-shrink:0; }
.player-info { overflow:hidden; padding-left:2px; }
.player-name { font-size:14px; font-weight:bold; color:#fff; white-space:nowrap; }
.rebuy-badge { display:inline-block; background:#b8860b; color:#000; font-size:9px; font-weight:bold; padding:1px 5px; border-radius:10px; margin-top:2px; }
.buyin-cell { text-align:center; font-size:12px; color:var(--muted); }
.rebuys-cell { display:flex; align-items:center; justify-content:center; gap:3px; }
.rebuy-btn { width:26px; height:26px; border-radius:4px; border:1px solid var(--border); background:var(--card2); color:var(--text); font-size:16px; cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.rebuy-count { font-size:11px; color:var(--accent); min-width:16px; text-align:center; }
.total-in-cell { text-align:center; font-size:13px; font-weight:bold; }
.remove-btn { background:none; border:none; color:var(--muted); font-size:18px; cursor:pointer; display:flex; align-items:center; justify-content:center; }
.cashout-tab { flex:1; overflow-y:auto; padding:12px 16px; display:flex; flex-direction:column; gap:10px; }
.cashout-card { background:var(--card2); border:1px solid var(--border); border-radius:10px; padding:12px; display:flex; align-items:center; gap:10px; }
.cashout-info { flex:1; min-width:0; }
.cashout-name { font-size:15px; font-weight:bold; margin-bottom:2px; color:#fff; }
.cashout-sub { font-size:11px; color:var(--muted); }
.cashout-input { width:90px; background:var(--bg); border:1px solid var(--border); border-radius:6px; color:var(--text); font-family:'Courier New',monospace; font-size:14px; padding:6px 10px; outline:none; text-align:right; flex-shrink:0; }
.cashout-pnl { font-size:13px; font-weight:bold; min-width:58px; text-align:right; flex-shrink:0; }
.pnl-positive { color:var(--green); }
.pnl-negative { color:var(--red); }
.payout-tab { flex:1; overflow-y:auto; padding:12px 16px; }
.payout-header-label { font-size:9px; letter-spacing:2px; color:var(--muted); text-transform:uppercase; margin-bottom:12px; }
.payout-card { background:var(--card2); border:1px solid var(--border); border-radius:10px; padding:14px; margin-bottom:10px; display:flex; align-items:center; gap:8px; }
.payout-from { flex:1; }
.payout-from-name { font-size:15px; font-weight:bold; color:var(--red); }
.payout-from-label { font-size:10px; color:var(--muted); text-transform:uppercase; letter-spacing:1px; }
.payout-to { flex:1; text-align:right; }
.payout-to-name { font-size:15px; font-weight:bold; color:var(--green); }
.payout-to-label { font-size:10px; color:var(--muted); text-transform:uppercase; letter-spacing:1px; }
.payout-amount { font-size:20px; font-weight:bold; color:var(--accent); text-align:center; min-width:65px; }
.no-payout { text-align:center; color:var(--muted); padding:40px 20px; font-size:13px; }
.summary-box { background:var(--card2); border:1px solid var(--border); border-radius:10px; padding:12px; margin-bottom:16px; }
.summary-row { display:flex; justify-content:space-between; padding:4px 0; font-size:13px; }
.summary-row span:first-child { color:var(--muted); }
.history-tab { flex:1; overflow-y:auto; padding:12px 16px; display:flex; flex-direction:column; gap:12px; }
.history-empty { text-align:center; color:var(--muted); padding:40px 20px; font-size:13px; line-height:1.8; }
.history-card { background:var(--card2); border:1px solid var(--border); border-radius:10px; overflow:hidden; }
.history-card-header { padding:12px 14px; display:flex; justify-content:space-between; align-items:center; cursor:pointer; }
.history-date { font-size:10px; color:var(--muted); letter-spacing:1px; margin-top:3px; }
.history-game-name { font-size:13px; font-weight:bold; color:#fff; }
.history-pot { font-size:14px; font-weight:bold; color:var(--accent); }
.history-chevron { color:var(--muted); font-size:11px; transition:transform 0.2s; margin-left:6px; }
.history-chevron.open { transform:rotate(90deg); }
.history-body { display:none; border-top:1px solid var(--border); }
.history-summary { padding:10px 14px; border-bottom:1px solid var(--border); display:flex; gap:20px; }
.history-stat-label { font-size:9px; color:var(--muted); letter-spacing:1px; text-transform:uppercase; margin-bottom:2px; }
.history-stat-value { font-size:13px; font-weight:bold; color:#fff; }
.history-players { padding:10px 14px; display:flex; flex-direction:column; gap:8px; }
.history-player-row { display:flex; align-items:center; gap:8px; }
.history-player-name { flex:1; font-size:13px; color:#fff; }
.history-player-in { font-size:11px; color:var(--muted); min-width:45px; text-align:right; }
.history-player-pnl { font-size:13px; font-weight:bold; min-width:55px; text-align:right; }
.history-clear-btn { background:none; border:1px solid var(--red); border-radius:6px; color:var(--red); font-family:'Courier New',monospace; font-size:11px; padding:10px; cursor:pointer; letter-spacing:1px; width:100%; margin-top:4px; }
.save-indicator { position:fixed; bottom:12px; right:12px; background:var(--card2); border:1px solid var(--border); border-radius:20px; padding:5px 12px; font-size:10px; color:var(--muted); letter-spacing:1px; opacity:0; transition:opacity 0.4s; pointer-events:none; z-index:100; }
.save-indicator.show { opacity:1; }
::-webkit-scrollbar { width:3px; }
::-webkit-scrollbar-track { background:transparent; }
::-webkit-scrollbar-thumb { background:var(--border); border-radius:2px; }
</style>
</head>
<body>
<div class="app">
  <div class="header">
    <div class="header-title">🃏 Poker Tracker</div>
    <button class="icon-btn" onclick="resetGame()">↺</button>
  </div>
  <div class="stats-bar">
    <div class="stat"><div class="stat-label">Pot</div><div class="stat-value" id="stat-pot">$0</div></div>
    <div class="stat"><div class="stat-label">Players</div><div class="stat-value white" id="stat-players">0</div></div>
    <div class="stat"><div class="stat-label">Remaining</div><div class="stat-value" id="stat-remaining">$0</div></div>
  </div>
  <div class="game-info">
    <div class="game-field">
      <label>Game</label>
      <input type="text" id="game-name" value="Friday Night Game" oninput="saveState()" />
    </div>
    <div class="game-field" style="flex:0 0 80px">
      <label>Buy-in $</label>
      <input type="number" id="default-buyin" value="100" oninput="saveState()" />
    </div>
  </div>
  <div class="add-player-bar">
    <select id="player-select">
      <option value="">Select player...</option>
      <option>Rajeev</option><option>Sriram</option><option>Kishore</option>
      <option>Rao</option><option>Venkat</option><option>Kumar</option>
      <option>Ranga</option><option>Ramesh</option><option>Ravi</option>
      <option>Shiva</option><option>Krishna</option><option>Bhavani</option>
      <option>Gopi</option><option>Vijo</option><option>Kasi</option><option>Leela</option>
    </select>
    <input type="number" class="buyin-input" id="new-player-buyin" placeholder="$" />
    <button class="add-btn" onclick="addPlayer()">+ Add</button>
  </div>
  <div class="custom-bar" id="custom-bar">
    <input type="text" id="custom-name" placeholder="Type new player name..." />
    <button class="add-btn" onclick="addCustomPlayer()">+ Add</button>
  </div>
  <div class="new-player-row">
    <button class="new-player-btn" id="toggle-btn" onclick="toggleCustom()">+ NEW PLAYER</button>
  </div>
  <div class="tabs">
    <div class="tab active" onclick="switchTab('players')">Players</div>
    <div class="tab" onclick="switchTab('cashout')">Cash Out</div>
    <div class="tab" onclick="switchTab('payout')">Payouts</div>
    <div class="tab" onclick="switchTab('history')">History</div>
  </div>
  <div class="tab-content active" id="tab-players">
    <div class="players-header">
      <span></span><span>Player</span><span>Buy-in</span><span>Rebuys</span><span>Total</span><span></span>
    </div>
    <div class="players-list" id="players-list"></div>
  </div>
  <div class="tab-content" id="tab-cashout">
    <div class="cashout-tab" id="cashout-list"></div>
  </div>
  <div class="tab-content" id="tab-payout">
    <div class="payout-tab" id="payout-list"></div>
  </div>
  <div class="tab-content" id="tab-history">
    <div class="history-tab" id="history-list"></div>
  </div>
</div>
<div class="save-indicator" id="save-indicator">💾 SAVED</div>
<script>
  const COLORS = ['#c8f135','#e74c3c','#3498db','#9b59b6','#e67e22','#1abc9c','#f39c12','#2ecc71','#e91e63','#00bcd4','#ff6b6b','#4ecdc4','#45b7d1','#96ceb4','#ffeaa7','#dda0dd'];
  const STORAGE_KEY = 'friday-night-poker-state';
  const HISTORY_KEY = 'friday-night-poker-history';
  let players = [], cashouts = {}, activeTab = 'players', customOpen = false, saveTimer = null;
  let gameHistory = [];

  function saveState() {
    const state = { players, cashouts, activeTab, gameName: document.getElementById('game-name').value, defaultBuyin: document.getElementById('default-buyin').value };
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e) {}
    clearTimeout(saveTimer);
    const el = document.getElementById('save-indicator');
    el.classList.add('show');
    saveTimer = setTimeout(() => el.classList.remove('show'), 1200);
  }

  function loadState() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return false;
      const s = JSON.parse(raw);
      players = s.players || []; cashouts = s.cashouts || {}; activeTab = s.activeTab || 'players';
      if (s.gameName) document.getElementById('game-name').value = s.gameName;
      if (s.defaultBuyin) document.getElementById('default-buyin').value = s.defaultBuyin;
      return true;
    } catch(e) { return false; }
  }

  function saveHistory() { try { localStorage.setItem(HISTORY_KEY, JSON.stringify(gameHistory)); } catch(e) {} }
  function loadHistory() { try { const raw = localStorage.getItem(HISTORY_KEY); if (raw) gameHistory = JSON.parse(raw); } catch(e) { gameHistory = []; } }

  function saveGameToHistory() {
    if (players.length === 0) return;
    const pot = getTotalPot();
    const gameName = document.getElementById('game-name').value || 'Friday Night Game';
    const now = new Date();
    const dateStr = now.toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric', year:'numeric' });
    const timeStr = now.toLocaleTimeString('en-US', { hour:'2-digit', minute:'2-digit' });
    const playerResults = players.map(p => {
      const tin = totalIn(p);
      const hasOut = cashouts[p.id] !== '' && cashouts[p.id] !== null && cashouts[p.id] !== undefined;
      const out = hasOut ? parseFloat(cashouts[p.id]) : null;
      const pnl = hasOut ? out - tin : null;
      return { name: p.name, color: p.color, buyin: p.buyin, rebuys: p.rebuys, totalIn: tin, cashOut: out, pnl };
    });
    playerResults.sort((a, b) => (b.pnl || 0) - (a.pnl || 0));
    const winner = playerResults[0];
    gameHistory.unshift({ id: Date.now(), date: dateStr, time: timeStr, gameName, pot, playerCount: players.length, players: playerResults, winner: winner.name });
    saveHistory();
  }

  function getInitials(name) { return name.trim().split(' ').map(w => w[0]).join('').toUpperCase().slice(0,2); }

  function toggleCustom() {
    customOpen = !customOpen;
    document.getElementById('custom-bar').classList.toggle('visible', customOpen);
    document.getElementById('toggle-btn').classList.toggle('active', customOpen);
    document.getElementById('toggle-btn').textContent = customOpen ? '✕ CANCEL' : '+ NEW PLAYER';
    if (customOpen) document.getElementById('custom-name').focus();
  }

  function addPlayer() { const sel = document.getElementById('player-select'); const name = sel.value.trim(); if (!name) { sel.focus(); return; } addPlayerByName(name); sel.value = ''; }
  function addCustomPlayer() { const input = document.getElementById('custom-name'); const name = input.value.trim(); if (!name) { input.focus(); return; } addPlayerByName(name); input.value = ''; toggleCustom(); }

  function addPlayerByName(name) {
    if (players.find(p => p.name.toLowerCase() === name.toLowerCase())) { alert(name + ' is already in the game!'); return; }
    const defaultBuyin = parseFloat(document.getElementById('default-buyin').value) || 100;
    const buyin = parseFloat(document.getElementById('new-player-buyin').value) || defaultBuyin;
    const color = COLORS[players.length % COLORS.length];
    const id = Date.now() + Math.random();
    players.push({ id, name, buyin, rebuys: 0, color });
    cashouts[id] = '';
    document.getElementById('new-player-buyin').value = '';
    render(); saveState();
  }

  function switchTab(tab) {
    activeTab = tab;
    document.querySelectorAll('.tab').forEach((t,i) => t.classList.toggle('active', ['players','cashout','payout','history'][i] === tab));
    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    document.getElementById('tab-' + tab).classList.add('active');
    if (tab === 'payout') renderPayouts();
    if (tab === 'cashout') renderCashouts();
    if (tab === 'history') renderHistory();
    saveState();
  }

  function addRebuy(id) { const p = players.find(p => p.id === id); if (p) { p.rebuys++; render(); saveState(); } }
  function removeRebuy(id) { const p = players.find(p => p.id === id); if (p && p.rebuys > 0) { p.rebuys--; render(); saveState(); } }
  function removePlayer(id) { players = players.filter(p => p.id !== id); delete cashouts[id]; render(); saveState(); }

  function totalIn(p) { return p.buyin + (p.rebuys * p.buyin); }
  function getTotalPot() { return players.reduce((s, p) => s + totalIn(p), 0); }
  function getTotalCashedOut() { return players.reduce((s, p) => s + (cashouts[p.id] !== '' && cashouts[p.id] !== null ? parseFloat(cashouts[p.id]) : 0), 0); }

  function updateStats() {
    const pot = getTotalPot();
    document.getElementById('stat-pot').textContent = '$' + pot;
    document.getElementById('stat-players').textContent = players.length;
    document.getElementById('stat-remaining').textContent = '$' + (pot - getTotalCashedOut());
  }

  function render() { renderPlayers(); if (activeTab === 'cashout') renderCashouts(); if (activeTab === 'payout') renderPayouts(); if (activeTab === 'history') renderHistory(); updateStats(); }

  function renderPlayers() {
    const list = document.getElementById('players-list');
    if (players.length === 0) { list.innerHTML = '<div style="color:#555;font-size:13px;padding:24px;text-align:center">Select a player above to add them</div>'; return; }
    list.innerHTML = players.map(p => {
      const tin = totalIn(p);
      return `<div class="player-row">
        <div class="avatar" style="background:${p.color}">${getInitials(p.name)}</div>
        <div class="player-info"><div class="player-name">${p.name}</div>${p.rebuys > 0 ? `<span class="rebuy-badge">+${p.rebuys}R</span>` : ''}</div>
        <div class="buyin-cell">$${p.buyin}</div>
        <div class="rebuys-cell">
          <button class="rebuy-btn" onclick="removeRebuy(${p.id})">−</button>
          <span class="rebuy-count">${p.rebuys > 0 ? p.rebuys : '—'}</span>
          <button class="rebuy-btn" onclick="addRebuy(${p.id})">+</button>
        </div>
        <div class="total-in-cell">$${tin}</div>
        <button class="remove-btn" onclick="removePlayer(${p.id})">×</button>
      </div>`;
    }).join('');
  }

  function renderCashouts() {
    const list = document.getElementById('cashout-list');
    if (players.length === 0) { list.innerHTML = '<div style="color:#555;font-size:13px;padding:24px;text-align:center">Add players first</div>'; return; }
    list.innerHTML = players.map(p => {
      const tin = totalIn(p);
      const hasValue = cashouts[p.id] !== '' && cashouts[p.id] !== null && cashouts[p.id] !== undefined;
      const out = hasValue ? parseFloat(cashouts[p.id]) : null;
      const pnl = hasValue ? out - tin : null;
      const pnlClass = hasValue ? (pnl >= 0 ? 'pnl-positive' : 'pnl-negative') : '';
      const pnlStr = hasValue ? (pnl >= 0 ? '+$' + pnl : '-$' + Math.abs(pnl)) : '—';
      return `<div class="cashout-card">
        <div class="avatar" style="background:${p.color}">${getInitials(p.name)}</div>
        <div class="cashout-info"><div class="cashout-name">${p.name}</div><div class="cashout-sub">Total in: $${tin}</div></div>
        <input class="cashout-input" type="number" placeholder="$0" value="${cashouts[p.id]}"
          oninput="cashouts[${p.id}]=this.value; updateStats(); saveState();" onchange="render()" />
        <div class="cashout-pnl ${pnlClass}">${pnlStr}</div>
      </div>`;
    }).join('');
  }

  function renderPayouts() {
    const list = document.getElementById('payout-list');
    if (players.length === 0) { list.innerHTML = '<div class="no-payout">Add players and enter cash out amounts to see payouts</div>'; return; }
    const pot = getTotalPot(), cashedOut = getTotalCashedOut();
    const allCashedOut = players.every(p => cashouts[p.id] !== '' && cashouts[p.id] !== null && cashouts[p.id] !== undefined);
    const balances = players.map(p => { const out = (cashouts[p.id] !== '' && cashouts[p.id] !== null) ? parseFloat(cashouts[p.id]) : 0; return { ...p, net: out - totalIn(p), out }; });
    let html = `<div class="summary-box">
      <div class="summary-row"><span>Total Pot</span><span style="color:var(--accent)">$${pot}</span></div>
      <div class="summary-row"><span>Cashed Out</span><span>$${cashedOut}</span></div>
      <div class="summary-row"><span>Difference</span><span style="color:${pot-cashedOut===0?'var(--green)':'var(--red)'}">$${pot-cashedOut}</span></div>
    </div>`;
    if (!allCashedOut) { html += '<div class="no-payout">Enter cash out amounts for all players to calculate payouts</div>'; list.innerHTML = html; return; }
    const debtors = balances.filter(p => p.net < 0).map(p => ({ name: p.name, amount: Math.abs(p.net) }));
    const creditors = balances.filter(p => p.net > 0).map(p => ({ name: p.name, amount: p.net }));
    debtors.sort((a,b) => b.amount - a.amount); creditors.sort((a,b) => b.amount - a.amount);
    const transactions = [], d = debtors.map(x => ({...x})), c = creditors.map(x => ({...x}));
    let i = 0, j = 0;
    while (i < d.length && j < c.length) {
      const amt = Math.min(d[i].amount, c[j].amount);
      if (amt >= 1) transactions.push({ from: d[i].name, to: c[j].name, amount: Math.round(amt) });
      d[i].amount -= amt; c[j].amount -= amt;
      if (d[i].amount < 1) i++; if (c[j].amount < 1) j++;
    }
    if (transactions.length === 0) { html += '<div class="no-payout">✅ All square! No payments needed.</div>'; }
    else {
      html += `<div class="payout-header-label">💸 Who pays whom</div>`;
      html += transactions.map(t => `<div class="payout-card">
        <div class="payout-from"><div class="payout-from-label">Pays</div><div class="payout-from-name">${t.from}</div></div>
        <div class="payout-amount">$${t.amount}</div>
        <div class="payout-to"><div class="payout-to-label">Receives</div><div class="payout-to-name">${t.to}</div></div>
      </div>`).join('');
    }
    list.innerHTML = html;
  }

  function toggleHistoryCard(id) {
    const body = document.getElementById('hbody-' + id);
    const chev = document.getElementById('hchev-' + id);
    const isOpen = body.style.display === 'block';
    body.style.display = isOpen ? 'none' : 'block';
    chev.classList.toggle('open', !isOpen);
  }

  function renderHistory() {
    const list = document.getElementById('history-list');
    if (gameHistory.length === 0) { list.innerHTML = '<div class="history-empty">No games saved yet.<br><br>Play a game, enter cash outs,<br>then tap ↺ Reset to save here. 🃏</div>'; return; }
    let html = gameHistory.map(g => {
      const playerRows = g.players.map(p => {
        const pnlStr = p.pnl !== null ? (p.pnl >= 0 ? `+$${p.pnl}` : `-$${Math.abs(p.pnl)}`) : '—';
        const pnlClass = p.pnl !== null ? (p.pnl >= 0 ? 'pnl-positive' : 'pnl-negative') : '';
        const rebuysStr = p.rebuys > 0 ? ` <span style="color:var(--muted);font-size:10px">+${p.rebuys}R</span>` : '';
        return `<div class="history-player-row">
          <div class="avatar" style="background:${p.color};width:24px;height:24px;font-size:9px;flex-shrink:0">${getInitials(p.name)}</div>
          <div class="history-player-name">${p.name}${rebuysStr}</div>
          <div class="history-player-in">$${p.totalIn}</div>
          <div class="history-player-pnl ${pnlClass}">${pnlStr}</div>
        </div>`;
      }).join('');
      return `<div class="history-card">
        <div class="history-card-header" onclick="toggleHistoryCard(${g.id})">
          <div>
            <div class="history-game-name">${g.gameName}</div>
            <div class="history-date">${g.date} · ${g.time}</div>
          </div>
          <div style="display:flex;align-items:center">
            <div class="history-pot">$${g.pot}</div>
            <div class="history-chevron" id="hchev-${g.id}">▶</div>
          </div>
        </div>
        <div class="history-body" id="hbody-${g.id}">
          <div class="history-summary">
            <div><div class="history-stat-label">Players</div><div class="history-stat-value">${g.playerCount}</div></div>
            <div><div class="history-stat-label">Pot</div><div class="history-stat-value">$${g.pot}</div></div>
            <div><div class="history-stat-label">🏆 Winner</div><div class="history-stat-value" style="color:var(--accent)">${g.winner}</div></div>
          </div>
          <div class="history-players">${playerRows}</div>
        </div>
      </div>`;
    }).join('');
    html += `<button class="history-clear-btn" onclick="clearHistory()">🗑 CLEAR ALL HISTORY</button>`;
    list.innerHTML = html;
  }

  function clearHistory() {
    if (!confirm('Clear all game history? This cannot be undone.')) return;
    gameHistory = []; saveHistory(); renderHistory();
  }

  function resetGame() {
    if (players.length === 0) return;
    if (!confirm('Reset the game? It will be saved to History.')) return;
    saveGameToHistory();
    players = []; cashouts = {};
    document.getElementById('game-name').value = 'Friday Night Game';
    localStorage.removeItem(STORAGE_KEY);
    render();
    switchTab('history');
  }

  document.getElementById('custom-name').addEventListener('keydown', e => { if (e.key === 'Enter') addCustomPlayer(); });

  loadHistory();
  const restored = loadState();
  if (restored && activeTab !== 'players') { switchTab(activeTab); } else { render(); }
</script>
</body>
</html>
